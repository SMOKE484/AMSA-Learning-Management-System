{
  "expo": {
    "name": "AMSA LMS",
    "slug": "AMSA-Mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/amsaIcon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/amsaLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vhulenda.AMSAMobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "AMSA needs photo library access to set your profile picture.",
        "NSCameraUsageDescription": "AMSA needs camera access to take a profile picture."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.vhulenda.AMSAMobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/amsaIcon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/amsaLogo.png"
    },
    "plugins": [
      "expo-build-properties",
      "expo-web-browser",
      "expo-router",
      "expo-font",
      ["expo-image-picker"],
      [
        "expo-notifications",
        {
          "icon": "./assets/amsaIcon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/8bb4dd4c-4aa2-4283-b5a2-83ca9b27f39d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "8bb4dd4c-4aa2-4283-b5a2-83ca9b27f39d"
      }
    },
    "owner": "vhulenda"
  }
}